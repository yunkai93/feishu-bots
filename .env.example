# Shared Feishu app credentials
FEISHU_APP_ID=
FEISHU_APP_SECRET=
FEISHU_CHAT_ID=

# Briefing output target
BRIEFING_OUTPUT_REPO_PATH=/path/to/your/output-repo
BRIEFING_OUTPUT_FILE_PATH=outputs/AI Briefing.md
BRIEFING_OUTPUT_TITLE=AI早报
BRIEFING_OUTPUT_WEB_URL=
BRIEFING_PUBLISH_REMOTE=origin
BRIEFING_PUBLISH_BRANCH=main
BRIEFING_GIT_PUSH=1

# Chat bot runtime
CHAT_BOT_SANDBOX_DIR=/tmp/feishu-bots-chat
